{
  "expo": {
    "name": "M&RC Travel",
    "slug": "travexmobile",
    "version": "1.0.0",
    "scheme": "travex",
    "orientation": "portrait",
    "icon": "./assets/images/LastPushLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/LastPushLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mrc.travex"
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.yourname.capsapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/MobileIcon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-image",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "247d393c-a719-405c-9d69-0ca890288718"
      }
    },
    "owner": ""
  }
}